# ==============================================================================
# CONFIGURACIÓN GLOBAL - SERVER ARCHIVO
# ==============================================================================
# Este archivo centraliza TODA la configuración del sistema.
# El ingeniero de infraestructura SOLO debe modificar este archivo.
#
# INSTRUCCIONES:
# 1. Copiar este archivo y renombrarlo a .env (si no existe)
# 2. Modificar los valores según el entorno de despliegue
# 3. Ejecutar: docker compose up -d
# ==============================================================================

# ==============================================================================
# CONFIGURACIÓN DE RED Y DOMINIO
# ==============================================================================
# Dominio principal del servidor (puede ser IP, localhost, o dominio)
# Ejemplos:
#   - localhost (desarrollo local)
#   - 192.168.1.100 (IP local)
#   - gestionarchivo.duckdns.org (dominio público)
#   - servidor.empresa.com (dominio corporativo)
DOMAIN=localhost

# IP local de WSL o servidor (para acceso desde Windows)
# Obtener con: ip addr show eth0 | grep inet
LOCAL_IP=172.29.48.1

# Puerto HTTP (normalmente 80)
HTTP_PORT=80

# Puerto HTTPS (normalmente 443)
HTTPS_PORT=443

# Protocolo por defecto (http o https)
# Cambiar a 'https' solo si tienes certificados SSL configurados
PROTOCOL=http

# Modo de ejecucion de Nginx
# - development: Usa Vite dev server con HMR (Hot Module Replacement)
# - production: Sirve archivos estaticos compilados (mas seguro, sin WebSocket)
# IMPORTANTE: En produccion siempre usar 'production' por seguridad
NGINX_MODE=production

# ==============================================================================
# BASE DE DATOS POSTGRESQL
# ==============================================================================
POSTGRES_DB=gestion_archivo_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIAR_EN_PRODUCCION
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=5433

# ==============================================================================
# REDIS
# ==============================================================================
REDIS_PORT=6379
REDIS_HOST=redis

# ==============================================================================
# DJANGO BACKEND
# ==============================================================================
# SECRET KEY - CAMBIAR EN PRODUCCIÓN
DJANGO_SECRET_KEY=GENERAR_CON_get_random_secret_key

# DEBUG - DESACTIVAR EN PRODUCCIÓN
DEBUG=True

# Hosts permitidos (separados por coma, sin espacios)
# Agregar IPs o dominios según sea necesario
ALLOWED_HOSTS=localhost,127.0.0.1,172.29.48.1,backend,gestionarchivo.duckdns.org

# Puerto interno del backend
BACKEND_PORT=8000

# ==============================================================================
# FRONTEND REACT/VITE
# ==============================================================================
# URL base de la API (USAR RUTA RELATIVA /api para producción)
# Solo cambiar si el frontend está en un servidor diferente al backend
VITE_API_URL=/api

# Puerto del servidor de desarrollo Vite (solo desarrollo)
VITE_DEV_PORT=4545

# ==============================================================================
# NGINX
# ==============================================================================
# Tamaño máximo de subida de archivos (en MB)
CLIENT_MAX_BODY_SIZE=2048M

# ==============================================================================
# NETAPP / NAS / REPOSITORIO CORPORATIVO
# ==============================================================================
# Ruta base del repositorio montado en el sistema
# IMPORTANTE: Este debe ser el punto de montaje CIFS/SMB en Linux
NETAPP_BASE_PATH=/mnt/repositorio/2510SP/H_Informacion_Consulta/Sub_Proy

# Servidor SMB/CIFS (solo para referencia, no usado directamente)
SMB_SERVER=172.21.54.24
SMB_SHARE=DirGesCat

# Credenciales CIFS (configuradas en /etc/cifs.credentials)
# Estos valores NO se usan directamente en la app, solo como referencia
SMB_USERNAME=andres.osorio@igac.gov.co
# SMB_PASSWORD se guarda en /etc/cifs.credentials por seguridad

# ==============================================================================
# JWT AUTHENTICATION
# ==============================================================================
JWT_SECRET_KEY=GENERAR_ALEATORIO_CON_openssl_rand
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ==============================================================================
# EMAIL NOTIFICATIONS
# ==============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_email@gmail.com
EMAIL_HOST_PASSWORD=TU_APP_PASSWORD_AQUI
DEFAULT_FROM_EMAIL=tu_email@gmail.com

# ==============================================================================
# GROQ AI (Pool de API Keys)
# ==============================================================================
# Pool de 5 API keys para balanceo de carga (separadas por comas)
GROQ_API_KEYS=gsk_KEY1,gsk_KEY2,gsk_KEY3,gsk_KEY4,gsk_KEY5

# Fallback key (primera del pool)
GROQ_API_KEY=gsk_KEY1

# Modelo a usar
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1000
GROQ_TEMPERATURE=0.3

# ==============================================================================
# OLLAMA (IA Local)
# ==============================================================================
# Habilitar/deshabilitar Ollama para procesamiento de IA local
OLLAMA_ENABLED=true

# URL del servicio Ollama (dentro de Docker network)
OLLAMA_BASE_URL=http://ollama:11434

# Modelo a usar (se descarga automaticamente con install.sh)
OLLAMA_MODEL=llama3.2:3b

# Timeout en segundos para peticiones a Ollama
OLLAMA_TIMEOUT=30

# ==============================================================================
# AUDITORÍA
# ==============================================================================
AUDIT_LOG_RETENTION_DAYS=366

# ==============================================================================
# FILE UPLOAD SETTINGS
# ==============================================================================
MAX_UPLOAD_SIZE_MB=2048
MAX_PATH_LENGTH=260
ALLOWED_EXTENSIONS=*

# ==============================================================================
# DICCIONARIO DE NOMENCLATURA
# ==============================================================================
DICTIONARY_FILE_PATH=../diccionario_archivo.json

# ==============================================================================
# PAPELERA DE RECICLAJE (TRASH)
# ==============================================================================
# Habilitar/deshabilitar papelera de reciclaje
TRASH_ENABLED=true

# Ruta relativa de la papelera dentro del repositorio
TRASH_PATH=04_bk/bk_temp_subproy/.trash

# Tamano maximo para respaldar en papelera (en GB)
# Archivos/directorios mayores se eliminan directamente sin respaldo
TRASH_MAX_SIZE_GB=5

# Dias de retencion antes de eliminar automaticamente
TRASH_RETENTION_DAYS=30

# ==============================================================================
# ARCHIVOS ADJUNTOS DE MENSAJERIA (CHAT ATTACHMENTS)
# ==============================================================================
# Ruta donde se guardan los archivos adjuntos de mensajes (relativa a NETAPP_BASE_PATH)
MESSAGE_ATTACHMENTS_PATH=04_bk/trans_doc_platform/message_attachments

# Tiempo de retencion de archivos adjuntos en dias (180 = 6 meses)
# Despues de este tiempo, los archivos se eliminan automaticamente
MESSAGE_ATTACHMENTS_RETENTION_DAYS=180

# ==============================================================================
# SSL/TLS CERTIFICATES (HTTPS)
# ==============================================================================
# Habilitar solo si tienes certificados SSL configurados
SSL_ENABLED=true

# Rutas de certificados SSL (dentro del contenedor nginx)
SSL_CERTIFICATE_PATH=/etc/nginx/ssl/certificate.crt
SSL_CERTIFICATE_KEY_PATH=/etc/nginx/ssl/private.key
SSL_CA_BUNDLE_PATH=/etc/nginx/ssl/ca_bundle.crt

# ==============================================================================
# ONLYOFFICE (Deshabilitado - bloqueado por firewall)
# ==============================================================================
USE_ONLYOFFICE=false
# ONLYOFFICE_API_KEY=
# ONLYOFFICE_JWT_SECRET=
# ONLYOFFICE_EDITOR_URL=https://documentserver.onlyoffice.com
# ONLYOFFICE_API_URL=https://api.onlyoffice.com

# ==============================================================================
# CELERY (Tareas asíncronas)
# ==============================================================================
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ==============================================================================
# FRONTEND URL
# ==============================================================================
# URL del frontend para emails y redirecciones
FRONTEND_URL=http://localhost
# PRODUCCION: FRONTEND_URL=https://gestionarchivo.igac.gov.co

# ==============================================================================
# LOGGING
# ==============================================================================
LOG_LEVEL=INFO

# ==============================================================================
# CORS (Cross-Origin Resource Sharing)
# ==============================================================================
# Orígenes permitidos (separados por coma)
# Agregar todos los dominios/IPs desde donde se accederá al backend
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://172.29.48.1,https://localhost,https://127.0.0.1,https://172.29.48.1,https://gestionarchivo.duckdns.org

# ==============================================================================
# NOTAS PARA DESPLIEGUE EN PRODUCCIÓN
# ==============================================================================
#
# 1. SEGURIDAD:
#    - Cambiar DJANGO_SECRET_KEY y JWT_SECRET_KEY a valores aleatorios
#    - Cambiar todas las contraseñas (POSTGRES_PASSWORD, EMAIL_HOST_PASSWORD)
#    - Configurar DEBUG=False
#    - Asegurar que SSL_ENABLED=true con certificados válidos
#
# 2. DOMINIO:
#    - Actualizar DOMAIN con el dominio o IP de producción
#    - Actualizar ALLOWED_HOSTS para incluir el dominio
#    - Actualizar CORS_ALLOWED_ORIGINS
#
# 3. NAS/REPOSITORIO:
#    - Verificar que NETAPP_BASE_PATH apunte al montaje CIFS correcto
#    - Configurar /etc/cifs.credentials con credenciales corporativas
#    - Agregar línea en /etc/fstab para montaje automático
#
# 4. SSL/HTTPS:
#    - Colocar certificados en ./nginx/ssl/
#    - Verificar que SSL_CERTIFICATE_PATH y SSL_CERTIFICATE_KEY_PATH sean correctos
#    - Cambiar PROTOCOL=https
#
# 5. BASE DE DATOS:
#    - Para producción, considerar PostgreSQL externo (no en Docker)
#    - Hacer backups regulares de postgres_data
#
# 6. TESTING ANTES DE PRODUCCIÓN:
#    docker compose config  # Verificar que todas las variables se lean correctamente
#    docker compose up -d   # Levantar servicios
#    docker compose logs -f # Ver logs en tiempo real
#
# ==============================================================================
